FROM golang:1.23-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN go build -ldflags "-X main.version=${VERSION}" -o /bin/irgsh-iso ./cmd/iso

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /bin/irgsh-iso /usr/bin/irgsh-iso
RUN mkdir -p /var/lib/irgsh/iso /var/log/irgsh
ENTRYPOINT ["/usr/bin/irgsh-iso"]
